# ============================================================
# Conviction Agent — environment template
# Copy to .env and fill. NEVER commit the real .env.
# ============================================================

# --- BSC / on-chain ---
BSC_RPC_URL=https://bsc-dataseed.binance.org/   # public RPC; swap for a private one if rate-limited
BSCSCAN_API_KEY=                                 # BscScan API key (smart-wallet discovery, holder queries)

# --- TWAK (Trust Wallet Agent Kit) — the ONLY signer ---
# Keys stay client-side. Agent signs + broadcasts locally.
TWAK_PRIVATE_KEY=                                # agent wallet private key (KEEP SECRET)
TWAK_WALLET_ADDRESS=                             # agent wallet public address
TWAK_X402_ENDPOINT=                              # x402 pay-per-request endpoint (if used)

# --- Twitter / X (PRIMARY social, paid wrapper) ---
TWITTER_WRAPPER=twitterapi.io                    # twitterapi.io | getxapi
TWITTER_API_KEY=                                 # wrapper API key

# --- Reddit (SECONDARY social, via PRAW / official API) ---
REDDIT_CLIENT_ID=                                # Reddit OAuth app client id (script app)
REDDIT_CLIENT_SECRET=                            # Reddit OAuth app secret
REDDIT_USER_AGENT=conviction-agent/0.1           # required by Reddit API
REDDIT_ACCOUNT_USER=                             # throwaway logged-in account (anonymous is 403-blocked)
REDDIT_ACCOUNT_PASS=

# --- CMC Agent Hub (structural sanity layer, via MCP) ---
CMC_API_KEY=                                     # CoinMarketCap / Agent Hub key

# --- LLM (rationale_text generation only) ---
ANTHROPIC_API_KEY=                               # Claude API key
ANTHROPIC_MODEL=claude-haiku-4-5-20251001        # cheap + fast; rationale is not on the hot path

# --- Runtime ---
LOG_LEVEL=INFO
DRY_RUN=true                                      # true = simulate trades, do not broadcast
