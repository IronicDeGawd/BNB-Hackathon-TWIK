# ============================================================
# Conviction Agent — environment template
# Copy to .env and fill. NEVER commit the real .env.
# ============================================================

# --- BSC / on-chain ---
BSC_RPC_URL=https://bsc-dataseed.binance.org/   # RPC for on-chain reads; use a keyed/private one for getLogs scans
# BSCSCAN_API_KEY=                              # optional; on-chain reads use a keyless RPC, not currently required

# --- TWAK (Trust Wallet Agent Kit) — execution + signer ---
# CLI auth (swaps/balance run through `twak`, which uses its own stored auth):
#   twak auth setup --api-key <k> --api-secret <s>   (creds from portal.trustwallet.com)
#   twak wallet create --password <pw>  +  twak wallet keychain save --password <pw>
#   twak init --api-key <ACCESS_ID> --api-secret <HMAC_SECRET>   (portal: Access ID + HMAC Secret)
TWAK_ACCESS_ID=                                  # portal "Access ID"  (== CLI --api-key)
TWAK_HMAC_SECRET=                                # portal "HMAC Secret" (== CLI --api-secret; shown once!)
TWAK_WALLET_ADDRESS=                             # agent address (from `twak wallet address --chain bsc`)
# Wallet password — the CLI signs locally with it (registration + swaps); never an exported key.
TWAK_WALLET_PASSWORD=                            # wallet password (or save once via `twak wallet keychain save`)
QUOTE_TOKEN=USDT                                 # base currency for buys/sells on BSC
# TWAK_BIN=twak                                  # path to the twak CLI (default: twak on PATH)

# --- Twitter / X (PRIMARY social, paid wrapper) ---
TWITTER_WRAPPER=twitterapi.io                    # twitterapi.io | getxapi
TWITTER_API_KEY=                                 # wrapper API key

# --- Reddit (SECONDARY social, via PRAW / official API) ---
REDDIT_CLIENT_ID=                                # Reddit OAuth app client id (script app)
REDDIT_CLIENT_SECRET=                            # Reddit OAuth app secret
REDDIT_USER_AGENT=conviction-agent/0.1           # required by Reddit API
REDDIT_ACCOUNT_USER=                             # throwaway logged-in account (anonymous is 403-blocked)
REDDIT_ACCOUNT_PASS=

# --- CMC Agent Hub (structural sanity layer, via MCP) ---
CMC_API_KEY=                                     # CoinMarketCap / Agent Hub key (pro.coinmarketcap.com)
CMC_TRANSPORT=mcp                                # mcp = use Agent Hub MCP (scores "Best Use of Agent Hub"); rest = classic Pro API. Falls back to REST on error.
# CMC_MCP_URL=https://mcp.coinmarketcap.com/mcp  # Agent Hub MCP endpoint (override if needed)
# CMC_TOOL_GLOBAL / CMC_TOOL_QUOTES / CMC_TOOL_DERIVATIVES — override if `python -m signals.cmc_mcp` shows different tool names

# --- LLM (rationale_text only) — Gemini Flash via Vertex AI / gcloud ADC ---
VERTEX_PROJECT=                                  # GCP project id; set to enable the Gemini rationale line (ADC auth)
VERTEX_REGION=us-central1                        # Gemini-on-Vertex region
LLM_CONFIRM=                                      # true = Gemini veto-only review before each live entry (needs VERTEX_PROJECT); empty = off

# --- Runtime ---
LOG_LEVEL=INFO
DRY_RUN=true                                      # true = simulate trades, do not broadcast

# --- Telegram notifications (optional; stream decisions + trades) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_RELAY_URL=        # optional: relay endpoint if your ISP blocks Telegram (POST {text})
TELEGRAM_RELAY_SECRET=     # shared secret for the relay
HEARTBEAT_CYCLES=4
